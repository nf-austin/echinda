manifest {
  name            = 'nf-austin/echidna'
  author          = 'Austin Varela'
  homePage        = 'https://github.com/nf-austin/echidna'
  description     = 'Bayesian gene dosage inference from scRNA-seq and (optionally) bulk WGS copy number'
  mainScript      = 'main.nf'
  nextflowVersion = '>=24.04.0'
  version         = '0.1.0'
  defaultBranch   = 'main'
}

params {
  // Input — choose one mode:
  // Auto-discovery (recommended): point at nf-austin/scrnaseq and nf-austin/wgs-cna output dirs
  scrna_dir  = null   // {scrna_dir}/{sample_id}/{sample_id}_annotated.h5ad
  wgs_dir    = null   // {wgs_dir}/{sample_id}.seg.txt  (optional; null = no-WGS mode for all samples)
  sample_map = null   // CSV (scrna_sample,wgs_sample) bridging mismatched naming conventions
  // Explicit samplesheet (multi-timepoint or custom): CSV with columns sample,h5ad,seg_txt
  input      = null

  outdir   = "results"
  genome   = 'hg38'  // UCSC genome name used for auto-download of refGene BED
  gene_bed = null     // override auto-download: path to existing BED (chr,start,end,gene_name)

  // Pre-processing
  num_genes    = null
  n_comps      = 15
  phenograph_k = 60
  n_neighbors  = 15

  // Training (EchidnaConfig)
  timepoint_label = "timepoint"
  counts_layer    = "counts"
  clusters        = "pheno_louvain"
  n_steps         = 10000
  learning_rate   = 0.1
  val_split       = 0.1
  patience        = null
  seed            = 42
  inverse_gamma   = false  // set true when running without WGS (more flexible eta variance)

  // CNV inference (echi_cnv)
  n_hmm_components   = 5
  n_gmm_components   = 5
  gaussian_smoothing = true
  filter_quantile    = 0.7
  smoother_sigma     = 6
  smoother_radius    = 8
  neut_method        = "peak"

  // Resource caps
  max_memory = 128.GB
  max_cpus   = 32
  max_time   = 72.h
}

process {
  resourceLimits = [
    memory: params.max_memory,
    cpus  : params.max_cpus,
    time  : params.max_time
  ]

  withName: 'SEG_TO_GENE_CN' {
    cpus          = 2
    memory        = { 8.GB  * task.attempt }
    time          = { 1.h   * task.attempt }
    errorStrategy = 'retry'
    maxRetries    = 2
  }

  withName: 'RUN_ECHIDNA' {
    cpus          = { 8  * task.attempt }
    memory        = { 32.GB * task.attempt }
    time          = { 12.h  * task.attempt }
    errorStrategy = 'retry'
    maxRetries    = 2
  }
}

profiles {
  docker {
    docker.enabled       = true
    docker.userEmulation = true
    singularity.enabled  = false
    conda.enabled        = false
  }
  singularity {
    singularity.enabled    = true
    singularity.autoMounts = true
    docker.enabled         = false
    conda.enabled          = true
  }
  conda {
    conda.enabled       = true
    docker.enabled      = false
    singularity.enabled = false
  }
}
